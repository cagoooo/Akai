rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function optionalString(data, field, maxLength) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLength);
    }

    function validWishCreate() {
      return request.resource.data.keys().hasOnly([
          'userId', 'userName', 'userPhoto', 'type', 'content', 'rating', 'status', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'userId', 'userName', 'type', 'content', 'status', 'createdAt'
        ])
        && request.resource.data.userId is string
        && request.resource.data.userId.size() <= 128
        && request.resource.data.userName is string
        && request.resource.data.userName.size() <= 80
        && optionalString(request.resource.data, 'userPhoto', 500)
        && request.resource.data.type in ['suggestion', 'feedback']
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 2000
        && (!( 'rating' in request.resource.data)
          || (request.resource.data.rating is int
            && request.resource.data.rating >= 1
            && request.resource.data.rating <= 5))
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time;
    }

    function validErrorLogCreate() {
      return request.auth != null
        && request.resource.data.keys().hasOnly([
          'level', 'message', 'stack', 'componentStack', 'url', 'userAgent',
          'timestamp', 'createdAt', 'metadata'
        ])
        && request.resource.data.keys().hasAll(['level', 'message'])
        && request.resource.data.level in ['error', 'warn', 'info', 'unhandledrejection']
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 2000
        && optionalString(request.resource.data, 'stack', 2500)
        && optionalString(request.resource.data, 'componentStack', 2500)
        && optionalString(request.resource.data, 'url', 1000)
        && optionalString(request.resource.data, 'userAgent', 500)
        && optionalString(request.resource.data, 'timestamp', 40);
    }

    // 訪客統計：公開顯示，寫入只走 recordPublicAnalytics Admin SDK。
    match /visitorStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 🆕 v3.6.67: 2026 AIFED 演講「現場提問」收件箱
    //   create: lineTalkWebhook Cloud Function 走 admin SDK（繞過 rules）
    //   read:   所有人可讀（演講當下 live-questions.html 公開顯示用）
    //   update/delete: 只有 admin custom claim（後台管理刪除測試訊息 / 隱藏不當訊息 / 釘選重要提問）
    //   注意：userId 已 hash 截 8 字，原 LINE userId 不會外洩
    match /talkQuestions/{msgId} {
      allow read: if true;
      allow create: if false;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // 分析資料只供 Admin 讀取；公開事件由 recordPublicAnalytics 驗證後以 Admin SDK 寫入。
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    // 🆕 v3.6.35: Web Vitals RUM + ToolIndex 熱門搜尋詞 sub-collection
    //   分別寫入 analytics/webVitals/{YYYY-MM-DD}/{metricId}
    //          analytics/toolIndexQueries/queries/{queryHash}
    //   必須明確開放，上述單層規則涵蓋不到 → 沒這條會被全部擋光。
    match /analytics/{docId}/{subCol}/{subDocId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 每日快照備份 — 只有 admin custom claim 可讀／可寫（一般使用者完全看不到）
    // dailySnapshot Cloud Function 走 admin SDK 不受 rules 限制
    match /analyticsSnapshots/{date} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // 🆕 v3.6.71: 健檢結果歷史 — admin 可讀（給 dashboard 趨勢圖），寫只走 admin SDK
    // 來源：performHealthCheck (manual or daily-cron) 跑完寫一筆
    match /healthCheckRuns/{runId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false; // 僅 admin SDK 寫入
    }

    // 🆕 v3.6.70: schema 漂移告警去重表（24h dedup 用）— admin 可讀，寫只走 admin SDK
    match /alertSilence/{alertKey} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // 工具使用統計公開顯示；寫入只走 incrementToolClick / beaconToolClick Admin SDK。
    match /toolUsageStats/{toolId} {
      allow read: if true;
      allow write: if false;
    }

    // 🆕 v3.6.49: 工具點擊事件記錄（細粒度，給 /admin 流量解析用）
    //   寫入：incrementToolClick Cloud Function 走 admin SDK（繞過 rules）
    //   讀取：只有 admin custom claim（一般使用者完全看不到 raw events）
    //   刪除：dailySnapshot 排程裁切 90 天前的舊 events
    match /toolClickEvents/{eventId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false; // 僅 admin SDK 寫入
    }

    // 錯誤日誌：匿名／Google 身分可依 schema 建立；只有 Admin 能查看與管理。
    match /engagementEvents/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.type in ['tool_click', 'blog_read'];
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    match /errorLogs/{logId} {
      allow create: if validErrorLogCreate();
      allow read, update, delete: if isAdmin();
    }

    // 成就系統 - 所有人可讀，僅認證用戶可寫
    match /achievements/{achievementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 用戶成就 - 需要認證
    match /userAchievements/{docId} {
      allow read, write: if request.auth != null;
    }

    // ==================== 評論功能 ====================

    // 工具評論 - 所有人可讀，認證用戶可寫
    match /toolReviews/{reviewId} {
      // 所有人可讀
      allow read: if true;
      // 認證用戶可新增
      allow create: if request.auth != null;
      // 只有評論作者可編輯/刪除，或任何認證用戶可更新點讚
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // 工具評分統計 - 所有人可讀，系統可寫
    match /toolRatings/{toolId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ==================== 許願池 ====================

    match /wishingWell/{wishId} {
      // 公開提交需通過 schema 白名單；讀取與管理必須有 Admin custom claim。
      allow create: if validWishCreate();
      allow read, update, delete: if isAdmin();
    }

    // ==================== 用戶收藏 ====================

    // 用戶收藏 - 只有本人可讀寫自己的收藏
    match /userFavorites/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 用戶最近使用工具 - 只有本人可讀寫自己的歷史（v3.6.8 新增）
    match /userRecentTools/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
